#!/usr/bin/env sh
MAVEN_WRAPPER_VERSION=0.5.6
# ----------------------------------------------------------------------------
# Maven wrapper script
# Generated by automation. Runs maven using project-local wrapper.
# ----------------------------------------------------------------------------
set -e

# Determine project root
PRG="$0"
while [ -h "$PRG" ] ; do
  ls=`ls -ld "$PRG"`
  link=`expr "$ls" : '.*-> \(.*\)$'`
  if expr "$link" : '/.*' > /dev/null; then
    PRG="$link"
  else
    PRG=`dirname "$PRG"`"/$link"
  fi
done
PRGDIR=`dirname "$PRG"`

WRAPPER_DIR="$PRGDIR/.mvn/wrapper"
DIST_URL="https://archive.apache.org/dist/maven/maven-3/3.9.16/binaries/apache-maven-3.9.16-bin.zip"
DIST_ZIP="$WRAPPER_DIR/apache-maven-3.9.16-bin.zip"
DIST_DIR="$WRAPPER_DIR/apache-maven-3.9.16"
MVN_BIN="$DIST_DIR/bin/mvn"

if [ ! -x "$MVN_BIN" ]; then
  echo "Bootstrapping Apache Maven 3.9.16..."
  mkdir -p "$WRAPPER_DIR"
  if [ ! -f "$DIST_ZIP" ]; then
    if command -v curl >/dev/null 2>&1; then
      curl -fsSL -o "$DIST_ZIP" "$DIST_URL" || { echo "Failed download $DIST_URL"; exit 1; }
    elif command -v wget >/dev/null 2>&1; then
      wget -q -O "$DIST_ZIP" "$DIST_URL" || { echo "Failed download $DIST_URL"; exit 1; }
    else
      echo "curl or wget required to download Maven distribution"
      exit 1
    fi
  fi
  if command -v unzip >/dev/null 2>&1; then
    unzip -q -d "$WRAPPER_DIR" "$DIST_ZIP" || { echo "Failed to unzip $DIST_ZIP"; exit 1; }
  else
    # try python fallback
    if command -v python3 >/dev/null 2>&1; then
      python3 - <<PY
import zipfile,sys
zipfile.ZipFile(sys.argv[1]).extractall(sys.argv[2])
PY
      if [ $? -ne 0 ]; then echo "Failed to unzip via python"; exit 1; fi
    else
      echo "unzip or python3 required to extract Maven distribution"
      exit 1
    fi
  fi
  chmod +x "$MVN_BIN" || true
fi

exec "$MVN_BIN" "$@"
