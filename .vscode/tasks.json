{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Maven: package (skip tests)",
      "type": "shell",
      "command": "./mvnw -T 1C -DskipTests install",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Maven: spring-boot:run (modulith-service)",
      "type": "shell",
      "command": "./mvnw -pl domain-mt-modulith-service spring-boot:run",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "isBackground": false,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
